<Window x:Class="MinimalTodoApp.Views.CalendarDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.Schedule.Title}"
        Width="760" Height="600"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="CanResizeWithGrip" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        FontFamily="Microsoft YaHei UI, Segoe UI">

    <Border Background="{DynamicResource WindowBg}" CornerRadius="12"
            BorderBrush="{DynamicResource Divider}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.35" Color="#000000" />
        </Border.Effect>

        <DockPanel Margin="2">
            <!-- 标题栏(可拖动 + 关闭) -->
            <Border x:Name="TitleBar" DockPanel.Dock="Top" Background="Transparent"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Padding="16,12,10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource S.Schedule.Title}"
                               FontSize="16" FontWeight="Bold" VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryText}" />
                    <Button Grid.Column="1" Style="{StaticResource CaptionButton}" Content="✕"
                            Click="Close_Click" />
                </Grid>
            </Border>

            <!-- 工具栏:视图切换 + 导航 + 时段标题 -->
            <Grid DockPanel.Dock="Top" Margin="16,4,16,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 视图切换 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <RadioButton x:Name="DayTab" GroupName="View" Style="{StaticResource PriorityChip}"
                                 Content="{DynamicResource S.Schedule.Day}" Checked="ViewTab_Checked" Tag="Day" />
                    <RadioButton x:Name="WeekTab" GroupName="View" Style="{StaticResource PriorityChip}"
                                 Content="{DynamicResource S.Schedule.Week}" Checked="ViewTab_Checked" Tag="Week"
                                 Margin="6,0,0,0" />
                    <RadioButton x:Name="MonthTab" GroupName="View" Style="{StaticResource PriorityChip}"
                                 Content="{DynamicResource S.Schedule.Month}" Checked="ViewTab_Checked" Tag="Month"
                                 Margin="6,0,0,0" IsChecked="True" />
                </StackPanel>

                <!-- 当前时段标题 -->
                <TextBlock Grid.Column="1" x:Name="PeriodTitle" HorizontalAlignment="Center"
                           VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryText}" />

                <!-- 导航 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource GhostButton}" Content="‹" FontSize="16" Padding="10,4"
                            ToolTip="{DynamicResource S.Schedule.Prev}" Click="Prev_Click" />
                    <Button Style="{StaticResource GhostButton}" Content="{DynamicResource S.Schedule.Today}"
                            Padding="10,6" Margin="6,0" Click="Today_Click" />
                    <Button Style="{StaticResource GhostButton}" Content="›" FontSize="16" Padding="10,4"
                            ToolTip="{DynamicResource S.Schedule.Next}" Click="Next_Click" />
                </StackPanel>
            </Grid>

            <!-- 日历主体(代码动态填充) -->
            <Border Margin="14,0,14,14" CornerRadius="8" Background="{DynamicResource ContentBg}"
                    BorderBrush="{DynamicResource Divider}" BorderThickness="1">
                <Grid x:Name="CalendarHost" />
            </Border>
        </DockPanel>
    </Border>
</Window>
