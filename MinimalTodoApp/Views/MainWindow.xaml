<Window x:Class="MinimalTodoApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dd="urn:gong-wpf-dragdrop"
        xmlns:tb="clr-namespace:H.NotifyIcon;assembly=H.NotifyIcon.Wpf"
        xmlns:v="clr-namespace:MinimalTodoApp.Views"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Todo" Height="640" Width="680"
        Icon="/Assets/app.ico"
        MinHeight="420" MinWidth="320"
        ShowInTaskbar="False"
        WindowStyle="None" ResizeMode="CanResize"
        AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        FontFamily="Microsoft YaHei UI, Segoe UI">

    <!-- 自定义窗口外观：去掉系统默认标题栏，自绘标题栏，圆角，但保留拖动/缩放/贴边 -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="30" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- 收集箱便签项模板(未分组列表与各分组列表共用):图标 + 标题;右键删除 -->
        <DataTemplate x:Key="NoteItemTemplate">
            <Grid Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                  ToolTip="{Binding DisplayTitle}">
                <Grid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{DynamicResource S.Note.Delete}" Click="InboxDeleteNote_Click" />
                    </ContextMenu>
                </Grid.ContextMenu>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&#xE70B;"
                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedText}" />
                <TextBlock Grid.Column="1" Text="{Binding DisplayTitle}" Margin="6,0,0,0"
                           VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource PrimaryText}" />
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <!-- 圆角外壳：AllowsTransparency 下用 Border 自绘圆角 -->
    <Border x:Name="RootBorder" Background="{DynamicResource WindowBg}" CornerRadius="10"
            BorderBrush="{DynamicResource Divider}" BorderThickness="1"
            SnapsToDevicePixels="True">
        <Border.Clip>
            <RectangleGeometry x:Name="RootClip" RadiusX="10" RadiusY="10"
                               Rect="0,0,680,640" />
        </Border.Clip>
        <Grid>
            <!-- 系统托盘图标 -->
            <tb:TaskbarIcon x:Name="TrayIcon"
                            ToolTipText="{DynamicResource S.Tray.ToolTip}"
                            IconSource="/Assets/app.ico"
                            TrayMouseDoubleClick="TrayIcon_DoubleClick">
                <tb:TaskbarIcon.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{DynamicResource S.Tray.Show}" Click="ShowMenuItem_Click" />
                        <Separator />
                        <MenuItem Header="{DynamicResource S.Tray.Exit}" Click="ExitMenuItem_Click" />
                    </ContextMenu>
                </tb:TaskbarIcon.ContextMenu>
            </tb:TaskbarIcon>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- ==================== 自定义标题栏（按钮在右；整条可拖动 + 右键菜单） ==================== -->
                <Grid Grid.Row="0" Background="{DynamicResource TitleBarBg}"
                      shell:WindowChrome.IsHitTestVisibleInChrome="True"
                      MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- App 名称（左） -->
                    <TextBlock Grid.Column="0" Text="✓ Todo" VerticalAlignment="Center"
                               Margin="14,0,0,0" FontWeight="SemiBold" FontSize="14"
                               Foreground="{DynamicResource PrimaryText}" />

                    <!-- 置顶按钮 + 设置（三横）按钮：位于交通灯左侧 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <!-- 应用置顶图钉：勾选则窗口始终最前(替代旧的右键标题栏菜单) -->
                        <ToggleButton x:Name="AlwaysOnTopToggle" Style="{StaticResource CaptionToggleButton}"
                                      IsChecked="{Binding AlwaysOnTop, Mode=TwoWay}"
                                      ToolTip="{DynamicResource S.AlwaysOnTop}">
                            <TextBlock Text="&#xE718;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" />
                        </ToggleButton>
                    <Grid VerticalAlignment="Center">
                        <ToggleButton x:Name="SettingsToggle" Style="{StaticResource CaptionToggleButton}"
                                      ToolTip="{DynamicResource S.Tip.Menu}">
                            <TextBlock Text="&#xE700;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" />
                        </ToggleButton>
                        <Popup IsOpen="{Binding IsChecked, ElementName=SettingsToggle}"
                               PlacementTarget="{Binding ElementName=SettingsToggle}"
                               Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                            <Border Background="{DynamicResource PopupBg}" CornerRadius="8"
                                    BorderBrush="{DynamicResource Divider}" BorderThickness="1"
                                    Padding="6" Margin="6" MinWidth="160">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.3" Color="#000000" />
                                </Border.Effect>
                                <StackPanel>
                                    <Button Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left"
                                            Padding="10,8" Click="Settings_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="14" Width="20" VerticalAlignment="Center" />
                                            <TextBlock Text="{DynamicResource S.MenuSettings}" FontSize="13" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>

                                    <!-- 语言切换:🌐 语言 标题 + 中文/English 选项(当前项打勾) -->
                                    <Border Height="1" Background="{DynamicResource Divider}" Margin="4,6" />
                                    <StackPanel Orientation="Horizontal" Margin="10,2,0,4">
                                        <TextBlock Text="&#xE774;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="13" Width="20" Foreground="{DynamicResource MutedText}" VerticalAlignment="Center" />
                                        <TextBlock Text="{DynamicResource S.MenuLanguage}"
                                                   FontSize="12" Foreground="{DynamicResource MutedText}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <Button Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left"
                                            Padding="10,7" Tag="zh-CN" Click="Language_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="✓" Width="16" FontSize="12"
                                                       Visibility="{Binding IsChineseSelected, Converter={StaticResource BoolToVis}}" />
                                            <TextBlock Text="中文" FontSize="13" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left"
                                            Padding="10,7" Tag="en" Click="Language_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="✓" Width="16" FontSize="12"
                                                       Visibility="{Binding IsEnglishSelected, Converter={StaticResource BoolToVis}}" />
                                            <TextBlock Text="English" FontSize="13" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    </StackPanel>

                    <!-- 交通灯（右）：关闭(红) / 最小化(黄) / 最大化(绿) -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center"
                                Margin="6,0,12,0"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource TrafficLightButton}" Tag="#FF5F57"
                                Content="✕" Click="HideToTray_Click"
                                ToolTip="{DynamicResource S.Tip.Close}" />
                        <Button Style="{StaticResource TrafficLightButton}" Tag="#FEBC2E"
                                Content="–" Click="Minimize_Click" ToolTip="{DynamicResource S.Tip.Minimize}" />
                        <Button Style="{StaticResource TrafficLightButton}" Tag="#28C840"
                                Content="+" Click="MaxRestore_Click" ToolTip="{DynamicResource S.Tip.MaxRestore}" />
                    </StackPanel>
                </Grid>

                <!-- ==================== 主体 ==================== -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <!-- 左侧单列侧边栏：宽度由代码维护（折叠=窄条，展开=持久化宽度，分隔条可拖动） -->
                        <ColumnDefinition x:Name="SidebarColumn" Width="150" MinWidth="0" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition x:Name="TaskColumn" Width="*" MinWidth="150" />
                        <!-- 右侧日程分隔条 + 日程面板(默认收起,宽度=0) -->
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition x:Name="ScheduleColumn" Width="0" />
                    </Grid.ColumnDefinitions>

                    <!-- ===== 左侧单列侧边栏（自上而下：全部任务 / 分组 / 新建分组 / 主题 / 三横） ===== -->
                    <Border x:Name="SidebarPanel" Grid.Column="0" Background="{DynamicResource SidebarBg}">
                        <Grid Margin="4,8">
                            <Grid.RowDefinitions>
                                <!-- 上部(*):分组区+收集箱整体可滚动;下部各项(使用说明/导入导出/主题/收起)紧贴底部 -->
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- 上部滚动区:所有待办+普通分组(可拖排序) → 新建分组 → 已完成 → 收集箱/便签 -->
                            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>

                            <!-- 分组列表：单击切换；拖动排序；右键操作菜单。折叠时仅显示颜色图标。
                                 SelectedItem 用 OneWay + SelectionChanged:已完成不在本列表里,避免它被选中时列表回写 null。 -->
                            <ListBox x:Name="GroupList" Margin="0" Style="{StaticResource FlatListBox}"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     ItemsSource="{Binding SidebarGroups}"
                                     SelectedItem="{Binding SelectedGroup, Mode=OneWay}"
                                     SelectionChanged="GroupList_SelectionChanged"
                                     dd:DragDrop.IsDragSource="True"
                                     dd:DragDrop.IsDropTarget="True"
                                     dd:DragDrop.DropHandler="{Binding}"
                                     dd:DragDrop.UseDefaultDragAdorner="True"
                                     dd:DragDrop.DefaultDragAdornerOpacity="0.85"
                                     dd:DragDrop.DropTargetAdornerBrush="{DynamicResource Accent}">
                                <ListBox.ItemContainerStyle>
                                    <!-- “所有待办”折叠时:隐藏其下普通分组容器(所有待办自身仍显示) -->
                                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource SidebarItemStyle}">
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsAllUncompletedGroup}" Value="False" />
                                                    <Condition Binding="{Binding DataContext.AllUncompletedGroup.IsCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid x:Name="GroupRow"
                                              Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                              ToolTip="{Binding DisplayName}"
                                              Margin="{Binding IndentMargin}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition x:Name="GroupDotCol" Width="20" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- 右键菜单：新建分组(任意分组都可) / 重命名 / 折叠展开(所有待办) / 更改图标 / 清空 / 删除 -->
                                            <Grid.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="{DynamicResource S.Group.New}"
                                                              Command="{Binding PlacementTarget.Tag.AddGroupCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                    <!-- 折叠/展开:仅“所有待办”显示(收起其下普通分组) -->
                                                    <MenuItem Header="{DynamicResource S.Group.ToggleCollapse}"
                                                              Visibility="{Binding PlacementTarget.DataContext.IsAllUncompletedGroup, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}"
                                                              Command="{Binding PlacementTarget.Tag.ToggleGroupCollapseCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                    <!-- 以下仅普通分组(所有待办除外) -->
                                                    <MenuItem Header="{DynamicResource S.Group.Rename}"
                                                              Visibility="{Binding PlacementTarget.DataContext.IsAllUncompletedGroup, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                                                              Command="{Binding PlacementTarget.Tag.RenameGroupCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                    <MenuItem Header="{DynamicResource S.Group.ChangeIcon}" Click="GroupChangeIcon_Click"
                                                              Visibility="{Binding PlacementTarget.DataContext.IsAllUncompletedGroup, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                                                    <Separator Visibility="{Binding PlacementTarget.DataContext.IsAllUncompletedGroup, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                                                    <MenuItem Header="{DynamicResource S.Group.Clear}"
                                                              Visibility="{Binding PlacementTarget.DataContext.IsAllUncompletedGroup, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                                                              Command="{Binding PlacementTarget.Tag.ClearGroupCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                    <MenuItem Header="{DynamicResource S.Group.Delete}"
                                                              Visibility="{Binding PlacementTarget.DataContext.IsAllUncompletedGroup, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                                                              Command="{Binding PlacementTarget.Tag.DeleteGroupCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                </ContextMenu>
                                            </Grid.ContextMenu>

                                            <Grid x:Name="GroupIcon" Grid.Column="0"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <!-- 字形图标(无自定义图片时显示) -->
                                                <TextBlock Text="{Binding Icon}"
                                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="15"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource PrimaryText}"
                                                           Visibility="{Binding HasIconImage, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                                                <!-- 自定义图片图标 -->
                                                <Image Source="{Binding IconImage, Converter={StaticResource PathToImage}}"
                                                       Width="16" Height="16" Stretch="UniformToFill"
                                                       Visibility="{Binding HasIconImage, Converter={StaticResource BoolToVis}}" />
                                            </Grid>
                                            <TextBlock Grid.Column="1" Text="{Binding DisplayName}" VerticalAlignment="Center"
                                                       Margin="6,0,0,0" FontSize="12" TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource PrimaryText}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DataContext.SidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <!-- 内联重命名输入框(右键“重命名”或新建分组时显示) -->
                                            <TextBox Grid.Column="1" Margin="6,0,0,0" FontSize="12" Padding="2,1"
                                                     Style="{StaticResource FlatTextBox}" VerticalAlignment="Center"
                                                     Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                                                     IsVisibleChanged="GroupNameEdit_IsVisibleChanged"
                                                     LostKeyboardFocus="GroupNameEdit_LostFocus"
                                                     KeyDown="GroupNameEdit_KeyDown" />
                                            <TextBlock Grid.Column="2" Text="{Binding ItemCount}" Margin="4,0"
                                                       VerticalAlignment="Center" FontSize="11"
                                                       Foreground="{DynamicResource MutedText}"
                                                       Visibility="{Binding DataContext.SidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <!-- 折叠时：颜色点跨满整行并居中，与其它图标对齐。
                                                 注意：必须把首列固定宽度 20 改成 *，否则在 39px 窄条里
                                                 20px 列比可用内容区还宽，居中的色点会被挤到右侧并被裁掉一半。 -->
                                            <DataTrigger Binding="{Binding DataContext.SidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                <Setter TargetName="GroupDotCol" Property="Width" Value="*" />
                                                <Setter TargetName="GroupIcon" Property="Grid.ColumnSpan" Value="3" />
                                                <Setter TargetName="GroupIcon" Property="HorizontalAlignment" Value="Center" />
                                                <Setter TargetName="GroupIcon" Property="Margin" Value="0" />
                                                <!-- 折叠侧栏(窄条)时取消层级缩进，避免图标被挤偏/裁切 -->
                                                <Setter TargetName="GroupRow" Property="Margin" Value="0" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- (新建分组已移到分组右键菜单:右键任意分组 → 新建分组,新分组进入内联重命名) -->

                            <!-- 已完成:顶层独立成行(与「所有待办」对称,不缩进);点击切到已完成视图,高亮跟随 IsCompletedSelected -->
                            <Button x:Name="CompletedRow" Margin="0,2,0,0" Height="32" Padding="6,0"
                                    HorizontalContentAlignment="Stretch" Click="Completed_Click"
                                    ToolTip="{Binding CompletedGroup.DisplayName}">
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="{DynamicResource S.Group.New}"
                                                  Command="{Binding PlacementTarget.DataContext.AddGroupCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </ContextMenu>
                                </Button.ContextMenu>
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompletedSelected}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource SelectedItemBg}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding CompletedGroup.Icon}"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="15"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{DynamicResource PrimaryText}" />
                                    <TextBlock Grid.Column="1" Text="{Binding CompletedGroup.DisplayName}" Margin="6,0,0,0"
                                               VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource PrimaryText}"
                                               Visibility="{Binding SidebarCollapsed, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                                    <TextBlock Grid.Column="2" Text="{Binding CompletedGroup.ItemCount}" Margin="4,0"
                                               VerticalAlignment="Center" FontSize="11"
                                               Foreground="{DynamicResource MutedText}"
                                               Visibility="{Binding SidebarCollapsed, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                                </Grid>
                            </Button>

                            <!-- ===== 收集箱(便签):可折叠便签树 ===== -->
                            <!-- 折叠侧栏(窄条)时:仅显示收集箱图标按钮,点击展开侧栏(需求6) -->
                            <Button Margin="0,12,0,0" Height="28" Padding="0"
                                    Style="{StaticResource GhostButton}"
                                    ToolTip="{DynamicResource S.Note.Inbox}"
                                    Command="{Binding ToggleSidebarCommand}"
                                    Visibility="{Binding SidebarCollapsed, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="14" />
                            </Button>

                            <!-- 展开侧栏时:完整收集箱树 -->
                            <StackPanel Margin="0,12,0,0"
                                        Visibility="{Binding SidebarCollapsed, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                                <!-- 收集箱 头:点击折叠/展开;右键「新建便签 / 新建分组 / 折叠展开」 -->
                                <Button Style="{StaticResource GhostButton}" Height="28" Padding="6,0"
                                        HorizontalContentAlignment="Stretch"
                                        Command="{Binding NotesVm.ToggleInboxCollapseCommand}">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="{DynamicResource S.Note.New}"
                                                      Command="{Binding PlacementTarget.DataContext.NotesVm.NewNoteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="{DynamicResource S.Note.NewGroup}"
                                                      Command="{Binding PlacementTarget.DataContext.NotesVm.NewNoteGroupCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <Separator />
                                            <MenuItem Header="{DynamicResource S.Note.ToggleCollapse}"
                                                      Command="{Binding PlacementTarget.DataContext.NotesVm.ToggleInboxCollapseCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <!-- 折叠指示箭头 -->
                                        <TextBlock Grid.Column="0" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="10" Width="14" TextAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SecondaryText}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="&#xE70D;" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding NotesVm.InboxCollapsed}" Value="True">
                                                            <Setter Property="Text" Value="&#xE76C;" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Grid.Column="1" Text="&#xE8B7;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="14" Width="18" TextAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SecondaryText}" />
                                        <TextBlock Grid.Column="2" Text="{DynamicResource S.Note.Inbox}" Margin="6,0,0,0" FontSize="12"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SecondaryText}" />
                                    </Grid>
                                </Button>

                                <!-- 收集箱内容(根折叠时整体隐藏) -->
                                <StackPanel Visibility="{Binding NotesVm.InboxCollapsed, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">

                                    <!-- 未分组便签(收集箱根下) -->
                                    <ListBox Margin="0,2,0,0" Style="{StaticResource FlatListBox}"
                                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                             ItemsSource="{Binding NotesVm.UngroupedNotes}"
                                             SelectedItem="{Binding NotesVm.SelectedNote, Mode=OneWay}"
                                             SelectionChanged="InboxNotes_SelectionChanged"
                                             ItemContainerStyle="{StaticResource SidebarItemStyle}"
                                             ItemTemplate="{StaticResource NoteItemTemplate}"
                                             dd:DragDrop.IsDragSource="True" dd:DragDrop.IsDropTarget="True"
                                             dd:DragDrop.DropHandler="{Binding NotesVm.DropHandler}"
                                             dd:DragDrop.UseDefaultDragAdorner="True"
                                             dd:DragDrop.DefaultDragAdornerOpacity="0.85"
                                             dd:DragDrop.DropTargetAdornerBrush="{DynamicResource Accent}" />

                                    <!-- 便签分组列表 -->
                                    <ItemsControl ItemsSource="{Binding NotesVm.NoteGroups}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <!-- 分组头:点击折叠/展开;右键菜单 -->
                                                    <Button Style="{StaticResource GhostButton}" Height="26" Padding="6,0" Margin="0,2,0,0"
                                                            HorizontalContentAlignment="Stretch"
                                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            Command="{Binding DataContext.NotesVm.ToggleNoteGroupCollapseCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="{DynamicResource S.Note.New}"
                                                                          Command="{Binding PlacementTarget.Tag.NotesVm.NewNoteInGroupCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                                <MenuItem Header="{DynamicResource S.Note.RenameGroup}"
                                                                          Command="{Binding PlacementTarget.Tag.NotesVm.RenameNoteGroupCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                                <MenuItem Header="{DynamicResource S.Note.ToggleCollapse}"
                                                                          Command="{Binding PlacementTarget.Tag.NotesVm.ToggleNoteGroupCollapseCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                                <Separator />
                                                                <MenuItem Header="{DynamicResource S.Note.DeleteGroup}"
                                                                          Click="NoteGroupDelete_Click" />
                                                            </ContextMenu>
                                                        </Button.ContextMenu>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                                       FontSize="10" Width="14" TextAlignment="Center" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource SecondaryText}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="&#xE70D;" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                                                                <Setter Property="Text" Value="&#xE76C;" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Grid.Column="1" Text="&#xE8B7;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                                       FontSize="13" Width="18" TextAlignment="Center" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource MutedText}" />
                                                            <!-- 分组名 / 内联重命名 -->
                                                            <TextBlock Grid.Column="2" Text="{Binding DisplayName}" Margin="6,0,0,0"
                                                                       VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis"
                                                                       Foreground="{DynamicResource PrimaryText}"
                                                                       Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                                                            <TextBox Grid.Column="2" Margin="6,0,0,0" FontSize="12" Padding="2,1"
                                                                     Style="{StaticResource FlatTextBox}" VerticalAlignment="Center"
                                                                     Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                     Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                                                                     IsVisibleChanged="NoteGroupNameEdit_IsVisibleChanged"
                                                                     LostKeyboardFocus="NoteGroupNameEdit_LostFocus"
                                                                     KeyDown="NoteGroupNameEdit_KeyDown" />
                                                        </Grid>
                                                    </Button>

                                                    <!-- 分组下便签(分组折叠时隐藏) -->
                                                    <ListBox Margin="14,0,0,0" Style="{StaticResource FlatListBox}"
                                                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                             Visibility="{Binding IsCollapsed, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                                                             ItemsSource="{Binding Notes}"
                                                             SelectedItem="{Binding DataContext.NotesVm.SelectedNote, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"
                                                             SelectionChanged="InboxNotes_SelectionChanged"
                                                             ItemContainerStyle="{StaticResource SidebarItemStyle}"
                                                             ItemTemplate="{StaticResource NoteItemTemplate}"
                                                             dd:DragDrop.IsDragSource="True" dd:DragDrop.IsDropTarget="True"
                                                             dd:DragDrop.DropHandler="{Binding DataContext.NotesVm.DropHandler, RelativeSource={RelativeSource AncestorType=Window}}"
                                                             dd:DragDrop.UseDefaultDragAdorner="True"
                                                             dd:DragDrop.DefaultDragAdornerOpacity="0.85"
                                                             dd:DragDrop.DropTargetAdornerBrush="{DynamicResource Accent}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- + 写点什么:新建便签(置于收集箱最底部) -->
                                    <Button Style="{StaticResource GhostButton}" Height="28" Padding="6,0" Margin="0,4,0,0"
                                            HorizontalContentAlignment="Left" Command="{Binding NotesVm.NewNoteCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE710;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="13" Width="18" TextAlignment="Center" VerticalAlignment="Center" />
                                            <TextBlock Text="{DynamicResource S.Note.WriteSomething}" Margin="6,0,0,0"
                                                       FontSize="12" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>

                                </StackPanel>
                            </ScrollViewer>

                            <!-- 使用说明（展开=图标+文字左对齐，折叠=书本图标居中） -->
                            <Button Grid.Row="1" Margin="0,2,0,0" Height="28" Padding="6,0"
                                    Click="Help_Click" ToolTip="{DynamicResource S.Help}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                        <Setter Property="HorizontalContentAlignment" Value="Left" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SidebarCollapsed}" Value="True">
                                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE82D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" Width="18"
                                               TextAlignment="Center" VerticalAlignment="Center" />
                                    <TextBlock Text="{DynamicResource S.Help}" Margin="6,0,0,0" FontSize="12" VerticalAlignment="Center"
                                               Visibility="{Binding SidebarCollapsed, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                                </StackPanel>
                            </Button>

                            <!-- 导入导出（展开=图标+文字左对齐，折叠=图标居中），与“使用说明”同款 -->
                            <Grid Grid.Row="2" Margin="0,2,0,0">
                                <ToggleButton x:Name="IoToggle" Height="28" Padding="6,0" ToolTip="{DynamicResource S.ImportExport}">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton" BasedOn="{StaticResource SidebarToggleButton}">
                                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SidebarCollapsed}" Value="True">
                                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ToggleButton.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE72D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" Width="18"
                                                   TextAlignment="Center" VerticalAlignment="Center" />
                                        <TextBlock Text="{DynamicResource S.ImportExport}" Margin="6,0,0,0" FontSize="12" VerticalAlignment="Center"
                                                   Visibility="{Binding SidebarCollapsed, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                                    </StackPanel>
                                </ToggleButton>
                                <Popup IsOpen="{Binding IsChecked, ElementName=IoToggle}"
                                       PlacementTarget="{Binding ElementName=IoToggle}"
                                       Placement="Top" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                    <Border Background="{DynamicResource PopupBg}" CornerRadius="10"
                                            BorderBrush="{DynamicResource Divider}" BorderThickness="1"
                                            Padding="6" Margin="6" MinWidth="170">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.3" Color="#000000" />
                                        </Border.Effect>
                                        <StackPanel>
                                            <Button Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left"
                                                    Padding="10,8" Click="ExportMarkdown_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="⬆" FontSize="13" Width="18"
                                                               TextAlignment="Center" VerticalAlignment="Center" />
                                                    <TextBlock Text="{DynamicResource S.Export.Md}" Margin="6,0,0,0" FontSize="12" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource GhostButton}" HorizontalContentAlignment="Left"
                                                    Padding="10,8" Click="ImportMarkdown_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="⬇" FontSize="13" Width="18"
                                                               TextAlignment="Center" VerticalAlignment="Center" />
                                                    <TextBlock Text="{DynamicResource S.Import.Md}" Margin="6,0,0,0" FontSize="12" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>

                            <!-- 修改主题：点击打开独立的主题选择窗口（可拖动、不遮挡主程序、实时预览） -->
                            <Button Grid.Row="3" x:Name="ThemeButton" Margin="0,2,0,0" Height="28" Padding="6,0"
                                    Click="OpenThemePicker_Click" ToolTip="{DynamicResource S.ChangeTheme}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                        <Setter Property="HorizontalContentAlignment" Value="Left" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SidebarCollapsed}" Value="True">
                                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE790;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" Width="18"
                                               TextAlignment="Center" VerticalAlignment="Center" />
                                    <TextBlock Text="{DynamicResource S.ChangeTheme}" Margin="6,0,0,0" FontSize="12" VerticalAlignment="Center"
                                               Visibility="{Binding SidebarCollapsed, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                                </StackPanel>
                            </Button>

                            <!-- 收起侧边栏（展开=三横图标+文字左对齐，折叠=三横图标居中，最底部） -->
                            <Button Grid.Row="4" Margin="0,2,0,0" Height="28" Padding="6,0"
                                    Command="{Binding ToggleSidebarCommand}" ToolTip="{DynamicResource S.Tip.ToggleSidebar}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                        <Setter Property="HorizontalContentAlignment" Value="Left" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SidebarCollapsed}" Value="True">
                                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE700;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" Width="18"
                                               TextAlignment="Center" VerticalAlignment="Center" />
                                    <TextBlock Text="{DynamicResource S.CollapseSidebar}" Margin="6,0,0,0" FontSize="12" VerticalAlignment="Center"
                                               Visibility="{Binding SidebarCollapsed, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- 分隔条：拖动调整侧边栏宽度（折叠时隐藏） -->
                    <GridSplitter x:Name="SidebarSplitter" Grid.Column="1" Width="5"
                                  HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                  Background="Transparent" ResizeBehavior="PreviousAndNext"
                                  Visibility="{Binding SidebarCollapsed, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />

                    <!-- ==================== 右侧：任务区（与便签视图互斥切换） ==================== -->
                    <Grid x:Name="TaskArea" Grid.Column="2" Margin="16,16,16,16"
                          Visibility="{Binding IsNotesViewOpen, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition x:Name="InputBarRow" Height="40" MinHeight="28" />
                        </Grid.RowDefinitions>

                        <!-- 头部：标题 + 排序（图标按钮，点击弹出选择） -->
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding CurrentTitle}" FontSize="17"
                                       FontWeight="Bold" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource PrimaryText}" />

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid VerticalAlignment="Center">
                                <ToggleButton x:Name="SortToggle" Style="{StaticResource CaptionToggleButton}"
                                              ToolTip="{Binding SortTooltip}">
                                    <TextBlock Text="&#xE8CB;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" />
                                </ToggleButton>
                                <Popup IsOpen="{Binding IsChecked, ElementName=SortToggle}"
                                       PlacementTarget="{Binding ElementName=SortToggle}"
                                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                    <Border Background="{DynamicResource PopupBg}" CornerRadius="8"
                                            BorderBrush="{DynamicResource Divider}" BorderThickness="1"
                                            Padding="6" Margin="6" MinWidth="150">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.3" Color="#000000" />
                                        </Border.Effect>
                                        <ItemsControl ItemsSource="{Binding SortOptions}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource GhostButton}"
                                                            HorizontalContentAlignment="Left" Padding="10,7"
                                                            Content="{Binding Label}" Tag="{Binding}"
                                                            Click="SortOption_Click" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </Popup>
                            </Grid>
                            <!-- 日程/日历:按截止时间在日历中查看待办(天/周/月) -->
                            <Button x:Name="ScheduleButton" Style="{StaticResource CaptionButton}"
                                    Margin="2,0,0,0"
                                    ToolTip="{DynamicResource S.Schedule.Tooltip}"
                                    Click="Schedule_Click">
                                <TextBlock Text="&#xE787;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" />
                            </Button>
                            </StackPanel>
                        </Grid>

                        <!-- 任务列表（支持拖拽排序 + 右键菜单 + Tab/Shift+Tab 调整缩进） -->
                        <ListBox x:Name="TaskList" Grid.Row="1" Style="{StaticResource FlatListBox}"
                                 ItemContainerStyle="{StaticResource TaskItemStyle}"
                                 ItemsSource="{Binding Items}"
                                 PreviewKeyDown="TaskList_PreviewKeyDown"
                                 dd:DragDrop.IsDragSource="True"
                                 dd:DragDrop.IsDropTarget="True"
                                 dd:DragDrop.DropHandler="{Binding}"
                                 dd:DragDrop.UseDefaultDragAdorner="True"
                                 dd:DragDrop.DefaultDragAdornerOpacity="0.85"
                                 dd:DragDrop.DropTargetAdornerBrush="{DynamicResource Accent}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <!-- Tag 绑定到主窗口 DataContext(=ViewModel)，供 ContextMenu 经 PlacementTarget.Tag 访问命令 -->
                                    <Grid Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- 右键菜单：编辑(优先级+DDL) / 置顶 / 缩进 / 移动到分组 / 删除 -->
                                        <Grid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="{DynamicResource S.Task.Edit}" Click="EditTask_Click" />
                                                <MenuItem Header="{DynamicResource S.Task.TogglePin}"
                                                          Command="{Binding PlacementTarget.Tag.TogglePinCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <Separator />
                                                <MenuItem Header="{DynamicResource S.Task.Indent}"
                                                          Command="{Binding PlacementTarget.Tag.IndentTaskCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <MenuItem Header="{DynamicResource S.Task.Outdent}"
                                                          Command="{Binding PlacementTarget.Tag.OutdentTaskCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                <!-- 移动到分组：子项动态绑定到普通分组（排除“已完成”） -->
                                                <MenuItem Header="{DynamicResource S.Task.MoveToGroup}"
                                                          ItemsSource="{Binding PlacementTarget.Tag.MoveTargetGroups, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.ItemContainerStyle>
                                                        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                                            <Setter Property="Header" Value="{Binding Name}" />
                                                            <EventSetter Event="Click" Handler="MoveToGroup_Click" />
                                                        </Style>
                                                    </MenuItem.ItemContainerStyle>
                                                </MenuItem>
                                                <Separator />
                                                <MenuItem Header="{DynamicResource S.Task.Delete}"
                                                          Command="{Binding PlacementTarget.Tag.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            </ContextMenu>
                                        </Grid.ContextMenu>

                                        <!-- 圆形勾选框（Col0）：圆环按优先级着色，完成时填充 + 白勾 -->
                                        <CheckBox Grid.Column="0" Style="{StaticResource TaskCheckBox}"
                                                  VerticalAlignment="Center" Margin="0,0,3,0"
                                                  BorderBrush="{Binding Priority, Converter={StaticResource PriorityToBrush}}"
                                                  IsChecked="{Binding IsCompleted, Mode=TwoWay}" />

                                        <!-- 标题（Col1）：默认显示文本（超长截断显示前部）；单击进入编辑 -->
                                        <Grid Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock x:Name="TitleText" Text="{Binding Title}"
                                                           VerticalAlignment="Center" Padding="2,1"
                                                           TextTrimming="CharacterEllipsis"
                                                           MouseLeftButtonUp="TaskTitle_Click"
                                                           Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                                                    <!-- 父待办(顶层)字号大、子待办(缩进)字号小，并跟随设置的基准字号 -->
                                                    <TextBlock.FontSize>
                                                        <MultiBinding Converter="{StaticResource IndentFontSize}">
                                                            <Binding Path="IndentLevel" />
                                                            <Binding Path="DataContext.FontSize" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                        </MultiBinding>
                                                    </TextBlock.FontSize>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                    <Setter Property="TextDecorations" Value="Strikethrough" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource MutedText}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <TextBox x:Name="TitleEdit" Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource TaskTitleTextBox}" VerticalAlignment="Center"
                                                         IsVisibleChanged="TitleEdit_IsVisibleChanged"
                                                         LostKeyboardFocus="TitleEdit_LostFocus"
                                                         KeyDown="TitleEdit_KeyDown"
                                                         Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                                    <TextBox.FontSize>
                                                        <MultiBinding Converter="{StaticResource IndentFontSize}">
                                                            <Binding Path="IndentLevel" />
                                                            <Binding Path="DataContext.FontSize" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                        </MultiBinding>
                                                    </TextBox.FontSize>
                                                </TextBox>
                                        </Grid>

                                        <!-- 子任务折叠（Col2，移到标题右侧行末，父任务单行不再两行）：圆角箭头 + “子任务 (n/m)”，点击折叠/展开 -->
                                        <Button Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Margin="8,0,0,0" Padding="4,2" Cursor="Hand"
                                                    Command="{Binding DataContext.ToggleCollapseCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="{DynamicResource S.Tip.CollapseArrow}"
                                                    Visibility="{Binding HasChildren, Converter={StaticResource BoolToVis}}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bg" Background="Transparent" CornerRadius="6"
                                                                Padding="{TemplateBinding Padding}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock x:Name="chev" Text="&#x2304;" FontSize="12" FontWeight="Bold"
                                                                           VerticalAlignment="Center" Margin="0,0,5,0"
                                                                           Foreground="{DynamicResource SecondaryText}" />
                                                                <TextBlock Text="{Binding SubtaskText}" FontSize="11"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{DynamicResource SecondaryText}" />
                                                            </StackPanel>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource CardHoverBg}" />
                                                            </Trigger>
                                                            <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                                                <!-- 折叠态：右角标 › -->
                                                                <Setter TargetName="chev" Property="Text" Value="&#x203A;" />
                                                                <Setter TargetName="chev" Property="Foreground" Value="{DynamicResource Accent}" />
                                                            </DataTrigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                        </Button>

                                        <!-- 距离 DDL 的倒计时（Col3）:胶囊徽章,底色用 CardHoverBg 柔和衬托、文字保持紧迫度配色 -->
                                        <Border Grid.Column="3" Margin="8,0,2,0" VerticalAlignment="Center"
                                                Background="{DynamicResource CardHoverBg}"
                                                CornerRadius="9" Padding="8,2"
                                                Visibility="{Binding HasDueDate, Converter={StaticResource BoolToVis}}"
                                                ToolTip="{Binding DueDetailText}">
                                            <TextBlock Text="{Binding DueCountdownText}" FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding DueState, Converter={StaticResource DueStateToBrush}}" />
                                        </Border>

                                        <!-- 置顶图钉 + 周期提醒小铃铛（Col4） -->
                                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE718;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="12" Margin="6,0,0,0"
                                                       VerticalAlignment="Center" Foreground="{DynamicResource Accent}"
                                                       Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}"
                                                       ToolTip="{DynamicResource S.Task.TogglePin}" />
                                            <TextBlock Text="&#xE7ED;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="12" Margin="6,0,2,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource WarningText}"
                                                       Visibility="{Binding HasReminder, Converter={StaticResource BoolToVis}}"
                                                       ToolTip="{DynamicResource S.Tip.ReminderBell}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- 输入任务文本后弹出：优先级（3 个色块）+ 截止时间按钮 + 周期提醒按钮 + 父待办 -->
                        <Border Grid.Row="2" Margin="0,10,0,0" Padding="10,8"
                                Background="{DynamicResource CardBg}" CornerRadius="8"
                                BorderBrush="{DynamicResource Divider}" BorderThickness="1"
                                Visibility="{Binding NewTaskTitle, Converter={StaticResource EmptyToVis}, ConverterParameter=Invert}">
                            <StackPanel>
                                <!-- 优先级:3 个色块，点击切换，被选中的有色描边 -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="58" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{DynamicResource S.Label.Priority}" VerticalAlignment="Center" FontSize="12"
                                               Foreground="{DynamicResource SecondaryText}" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <!-- 低 -->
                                        <Button Padding="14,4" Margin="0,0,6,0" FontSize="12" Cursor="Hand"
                                                Click="PriorityChip_Click" Tag="Low">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="b" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                                            Background="#1A10B981" BorderBrush="Transparent" BorderThickness="1.5">
                                                        <TextBlock Text="{DynamicResource S.Priority.Low}" Foreground="#10B981" FontWeight="SemiBold" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.NewTaskPriority, RelativeSource={RelativeSource AncestorType=Window}}" Value="Low">
                                                            <Setter TargetName="b" Property="BorderBrush" Value="#10B981" />
                                                            <Setter TargetName="b" Property="Background" Value="#3310B981" />
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <!-- 中 -->
                                        <Button Padding="14,4" Margin="0,0,6,0" FontSize="12" Cursor="Hand"
                                                Click="PriorityChip_Click" Tag="Medium">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="b" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                                            Background="#1AF59E0B" BorderBrush="Transparent" BorderThickness="1.5">
                                                        <TextBlock Text="{DynamicResource S.Priority.Medium}" Foreground="#F59E0B" FontWeight="SemiBold" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.NewTaskPriority, RelativeSource={RelativeSource AncestorType=Window}}" Value="Medium">
                                                            <Setter TargetName="b" Property="BorderBrush" Value="#F59E0B" />
                                                            <Setter TargetName="b" Property="Background" Value="#33F59E0B" />
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <!-- 高 -->
                                        <Button Padding="14,4" Margin="0,0,6,0" FontSize="12" Cursor="Hand"
                                                Click="PriorityChip_Click" Tag="High">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="b" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                                            Background="#1AEF4444" BorderBrush="Transparent" BorderThickness="1.5">
                                                        <TextBlock Text="{DynamicResource S.Priority.High}" Foreground="#EF4444" FontWeight="SemiBold" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.NewTaskPriority, RelativeSource={RelativeSource AncestorType=Window}}" Value="High">
                                                            <Setter TargetName="b" Property="BorderBrush" Value="#EF4444" />
                                                            <Setter TargetName="b" Property="Background" Value="#33EF4444" />
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <!-- 截止时间按钮 + 弹出选择 -->
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="58" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{DynamicResource S.Label.DueTime}" VerticalAlignment="Center" FontSize="12"
                                               Foreground="{DynamicResource SecondaryText}" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ToggleButton x:Name="DueTimeToggle" Padding="10,4" FontSize="12" MinWidth="120"
                                                      HorizontalContentAlignment="Left"
                                                      Style="{StaticResource SidebarToggleButton}"
                                                      Background="{DynamicResource InputBg}"
                                                      Content="{Binding NewTaskDueButtonText}" />
                                        <Button Content="{DynamicResource S.Clear}" Style="{StaticResource GhostButton}"
                                                Padding="8,3" Margin="6,0,0,0" FontSize="12"
                                                Command="{Binding ClearNewTaskDueCommand}"
                                                Visibility="{Binding HasNewTaskDue, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>

                                    <Popup IsOpen="{Binding IsChecked, ElementName=DueTimeToggle}"
                                           PlacementTarget="{Binding ElementName=DueTimeToggle}"
                                           Placement="Top" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                        <Border Background="{DynamicResource PopupBg}" CornerRadius="10"
                                                BorderBrush="{DynamicResource Divider}" BorderThickness="1"
                                                Padding="10" Margin="6" MinWidth="260">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.3" Color="#000000" />
                                            </Border.Effect>
                                            <StackPanel>
                                                <!-- 分钟 -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="{DynamicResource S.Unit.Minute}" Width="36" VerticalAlignment="Center" FontSize="12"
                                                               Foreground="{DynamicResource MutedText}" />
                                                    <Button Style="{StaticResource GhostButton}" Padding="9,3" Margin="0,0,5,0" FontSize="12"
                                                            Content="1" Background="{DynamicResource InputBg}"
                                                            Command="{Binding SetNewTaskQuickTimeCommand}" CommandParameter="1" />
                                                    <Button Style="{StaticResource GhostButton}" Padding="9,3" Margin="0,0,5,0" FontSize="12"
                                                            Content="10" Background="{DynamicResource InputBg}"
                                                            Command="{Binding SetNewTaskQuickTimeCommand}" CommandParameter="10" />
                                                    <Button Style="{StaticResource GhostButton}" Padding="9,3" Margin="0,0,5,0" FontSize="12"
                                                            Content="30" Background="{DynamicResource InputBg}"
                                                            Command="{Binding SetNewTaskQuickTimeCommand}" CommandParameter="30" />
                                                </StackPanel>
                                                <!-- 小时 -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="{DynamicResource S.Unit.Hour}" Width="36" VerticalAlignment="Center" FontSize="12"
                                                               Foreground="{DynamicResource MutedText}" />
                                                    <Button Style="{StaticResource GhostButton}" Padding="9,3" Margin="0,0,5,0" FontSize="12"
                                                            Content="1" Background="{DynamicResource InputBg}"
                                                            Command="{Binding SetNewTaskQuickTimeCommand}" CommandParameter="60" />
                                                    <Button Style="{StaticResource GhostButton}" Padding="9,3" Margin="0,0,5,0" FontSize="12"
                                                            Content="2" Background="{DynamicResource InputBg}"
                                                            Command="{Binding SetNewTaskQuickTimeCommand}" CommandParameter="120" />
                                                    <Button Style="{StaticResource GhostButton}" Padding="9,3" Margin="0,0,5,0" FontSize="12"
                                                            Content="5" Background="{DynamicResource InputBg}"
                                                            Command="{Binding SetNewTaskQuickTimeCommand}" CommandParameter="300" />
                                                </StackPanel>
                                                <!-- 天 -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="{DynamicResource S.Unit.Day}" Width="36" VerticalAlignment="Center" FontSize="12"
                                                               Foreground="{DynamicResource MutedText}" />
                                                    <Button Style="{StaticResource GhostButton}" Padding="9,3" Margin="0,0,5,0" FontSize="12"
                                                            Content="1" Background="{DynamicResource InputBg}"
                                                            Command="{Binding SetNewTaskQuickTimeCommand}" CommandParameter="1440" />
                                                    <Button Style="{StaticResource GhostButton}" Padding="9,3" Margin="0,0,5,0" FontSize="12"
                                                            Content="2" Background="{DynamicResource InputBg}"
                                                            Command="{Binding SetNewTaskQuickTimeCommand}" CommandParameter="2880" />
                                                    <Button Style="{StaticResource GhostButton}" Padding="9,3" Margin="0,0,5,0" FontSize="12"
                                                            Content="5" Background="{DynamicResource InputBg}"
                                                            Command="{Binding SetNewTaskQuickTimeCommand}" CommandParameter="7200" />
                                                </StackPanel>
                                                <!-- 周 -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="{DynamicResource S.Unit.Week}" Width="36" VerticalAlignment="Center" FontSize="12"
                                                               Foreground="{DynamicResource MutedText}" />
                                                    <Button Style="{StaticResource GhostButton}" Padding="9,3" Margin="0,0,5,0" FontSize="12"
                                                            Content="1" Background="{DynamicResource InputBg}"
                                                            Command="{Binding SetNewTaskQuickTimeCommand}" CommandParameter="10080" />
                                                    <Button Style="{StaticResource GhostButton}" Padding="9,3" Margin="0,0,5,0" FontSize="12"
                                                            Content="2" Background="{DynamicResource InputBg}"
                                                            Command="{Binding SetNewTaskQuickTimeCommand}" CommandParameter="20160" />
                                                    <Button Style="{StaticResource GhostButton}" Padding="9,3" Margin="0,0,5,0" FontSize="12"
                                                            Content="4" Background="{DynamicResource InputBg}"
                                                            Command="{Binding SetNewTaskQuickTimeCommand}" CommandParameter="40320" />
                                                </StackPanel>
                                                <!-- 自定义时间 -->
                                                <Border Background="{DynamicResource Divider}" Height="1" Margin="0,0,0,6" />
                                                <WrapPanel>
                                                    <TextBlock Text="{DynamicResource S.Custom}" Width="36" VerticalAlignment="Center" FontSize="12"
                                                               Foreground="{DynamicResource MutedText}" />
                                                    <DatePicker Width="112" Margin="0,0,4,4" VerticalContentAlignment="Center"
                                                                SelectedDate="{Binding NewTaskCustomDate, Mode=TwoWay}" />
                                                    <ComboBox Width="46" Margin="0,0,0,4" VerticalAlignment="Center"
                                                              ItemsSource="{Binding Hours}"
                                                              SelectedItem="{Binding NewTaskCustomHour, Mode=TwoWay}" />
                                                    <TextBlock Text=":" VerticalAlignment="Center" Margin="3,0"
                                                               Foreground="{DynamicResource PrimaryText}" />
                                                    <ComboBox Width="46" Margin="0,0,4,4" VerticalAlignment="Center"
                                                              ItemsSource="{Binding Minutes}"
                                                              SelectedItem="{Binding NewTaskCustomMinute, Mode=TwoWay}" />
                                                    <!-- (选了日期/时/分即自动设定，无需"设定"按钮) -->
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                </Grid>

                                <!-- 周期提醒按钮 + 弹出选择 -->
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="58" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{DynamicResource S.Label.Reminder}" VerticalAlignment="Center" FontSize="12"
                                               Foreground="{DynamicResource SecondaryText}" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ToggleButton x:Name="ReminderToggle" Padding="10,4" FontSize="12" MinWidth="120"
                                                      HorizontalContentAlignment="Left"
                                                      Style="{StaticResource SidebarToggleButton}"
                                                      Background="{DynamicResource InputBg}"
                                                      Content="{Binding NewTaskReminderButtonText}" />
                                        <Button Content="{DynamicResource S.Clear}" Style="{StaticResource GhostButton}"
                                                Padding="8,3" Margin="6,0,0,0" FontSize="12"
                                                Command="{Binding ClearNewTaskReminderCommand}"
                                                Visibility="{Binding NewTaskReminderEnabled, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>

                                    <Popup IsOpen="{Binding IsChecked, ElementName=ReminderToggle}"
                                           PlacementTarget="{Binding ElementName=ReminderToggle}"
                                           Placement="Top" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                        <Border Background="{DynamicResource PopupBg}" CornerRadius="10"
                                                BorderBrush="{DynamicResource Divider}" BorderThickness="1"
                                                Padding="10" Margin="6" MinWidth="260">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.3" Color="#000000" />
                                            </Border.Effect>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="{DynamicResource S.Unit.Minute}" Width="36" VerticalAlignment="Center" FontSize="12"
                                                               Foreground="{DynamicResource MutedText}" />
                                                    <Button Style="{StaticResource GhostButton}" Padding="9,3" Margin="0,0,5,0" FontSize="12"
                                                            Content="1" Background="{DynamicResource InputBg}"
                                                            Command="{Binding SetNewTaskReminderQuickCommand}" CommandParameter="1" />
                                                    <Button Style="{StaticResource GhostButton}" Padding="9,3" Margin="0,0,5,0" FontSize="12"
                                                            Content="10" Background="{DynamicResource InputBg}"
                                                            Command="{Binding SetNewTaskReminderQuickCommand}" CommandParameter="10" />
                                                    <Button Style="{StaticResource GhostButton}" Padding="9,3" Margin="0,0,5,0" FontSize="12"
                                                            Content="30" Background="{DynamicResource InputBg}"
                                                            Command="{Binding SetNewTaskReminderQuickCommand}" CommandParameter="30" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="{DynamicResource S.Unit.Hour}" Width="36" VerticalAlignment="Center" FontSize="12"
                                                               Foreground="{DynamicResource MutedText}" />
                                                    <Button Style="{StaticResource GhostButton}" Padding="9,3" Margin="0,0,5,0" FontSize="12"
                                                            Content="1" Background="{DynamicResource InputBg}"
                                                            Command="{Binding SetNewTaskReminderQuickCommand}" CommandParameter="60" />
                                                    <Button Style="{StaticResource GhostButton}" Padding="9,3" Margin="0,0,5,0" FontSize="12"
                                                            Content="2" Background="{DynamicResource InputBg}"
                                                            Command="{Binding SetNewTaskReminderQuickCommand}" CommandParameter="120" />
                                                    <Button Style="{StaticResource GhostButton}" Padding="9,3" Margin="0,0,5,0" FontSize="12"
                                                            Content="5" Background="{DynamicResource InputBg}"
                                                            Command="{Binding SetNewTaskReminderQuickCommand}" CommandParameter="300" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="{DynamicResource S.Unit.Day}" Width="36" VerticalAlignment="Center" FontSize="12"
                                                               Foreground="{DynamicResource MutedText}" />
                                                    <Button Style="{StaticResource GhostButton}" Padding="9,3" Margin="0,0,5,0" FontSize="12"
                                                            Content="1" Background="{DynamicResource InputBg}"
                                                            Command="{Binding SetNewTaskReminderQuickCommand}" CommandParameter="1440" />
                                                    <Button Style="{StaticResource GhostButton}" Padding="9,3" Margin="0,0,5,0" FontSize="12"
                                                            Content="2" Background="{DynamicResource InputBg}"
                                                            Command="{Binding SetNewTaskReminderQuickCommand}" CommandParameter="2880" />
                                                    <Button Style="{StaticResource GhostButton}" Padding="9,3" Margin="0,0,5,0" FontSize="12"
                                                            Content="5" Background="{DynamicResource InputBg}"
                                                            Command="{Binding SetNewTaskReminderQuickCommand}" CommandParameter="7200" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="{DynamicResource S.Unit.Week}" Width="36" VerticalAlignment="Center" FontSize="12"
                                                               Foreground="{DynamicResource MutedText}" />
                                                    <Button Style="{StaticResource GhostButton}" Padding="9,3" Margin="0,0,5,0" FontSize="12"
                                                            Content="1" Background="{DynamicResource InputBg}"
                                                            Command="{Binding SetNewTaskReminderQuickCommand}" CommandParameter="10080" />
                                                    <Button Style="{StaticResource GhostButton}" Padding="9,3" Margin="0,0,5,0" FontSize="12"
                                                            Content="2" Background="{DynamicResource InputBg}"
                                                            Command="{Binding SetNewTaskReminderQuickCommand}" CommandParameter="20160" />
                                                    <Button Style="{StaticResource GhostButton}" Padding="9,3" Margin="0,0,5,0" FontSize="12"
                                                            Content="4" Background="{DynamicResource InputBg}"
                                                            Command="{Binding SetNewTaskReminderQuickCommand}" CommandParameter="40320" />
                                                </StackPanel>
                                                <Border Background="{DynamicResource Divider}" Height="1" Margin="0,0,0,6" />
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{DynamicResource S.Custom}" Width="36" VerticalAlignment="Center" FontSize="12"
                                                               Foreground="{DynamicResource MutedText}" />
                                                    <TextBox Width="60" Style="{StaticResource FlatTextBox}" Padding="6,3" FontSize="12"
                                                             Text="{Binding NewTaskReminderCustomValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    <ComboBox Width="62" Margin="6,0,0,0" VerticalAlignment="Center"
                                                              ItemsSource="{Binding ReminderUnits}"
                                                              DisplayMemberPath="Label"
                                                              SelectedValuePath="Minutes"
                                                              SelectedValue="{Binding NewTaskReminderCustomUnitMinutes, Mode=TwoWay}" />
                                                    <!-- (输入数值/选单位即自动设为提醒，无需"设为提醒"按钮) -->
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                </Grid>

                                <!-- 父待办选择（创建子待办） -->
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="58" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{DynamicResource S.Label.Parent}" VerticalAlignment="Center" FontSize="12"
                                               Foreground="{DynamicResource SecondaryText}" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ComboBox MinWidth="170" VerticalAlignment="Center" FontSize="12"
                                                  ItemsSource="{Binding ParentCandidates}"
                                                  SelectedValue="{Binding NewTaskParentId, Mode=TwoWay}"
                                                  SelectedValuePath="Id"
                                                  DisplayMemberPath="Title"
                                                  ToolTip="{DynamicResource S.Tip.Parent}">
                                            <ComboBox.ItemContainerStyle>
                                                <Style TargetType="ComboBoxItem">
                                                    <Setter Property="Padding" Value="8,4" />
                                                </Style>
                                            </ComboBox.ItemContainerStyle>
                                        </ComboBox>
                                        <Button Content="{DynamicResource S.Clear}" Style="{StaticResource GhostButton}"
                                                Padding="8,3" Margin="6,0,0,0" FontSize="12"
                                                Command="{Binding ClearNewTaskParentCommand}"
                                                Visibility="{Binding HasNewTaskParent, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 输入栏顶部:可上下拖动的细分隔条，松开后记忆高度 -->
                        <GridSplitter x:Name="InputBarSplitter" Grid.Row="3" Height="5"
                                      HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                                      Background="Transparent" ResizeBehavior="PreviousAndNext"
                                      ResizeDirection="Rows" Cursor="SizeNS" Margin="0,4,0,0" />

                        <!-- 添加任务输入栏（底部，可拖动调整高度，持久化） -->
                        <Border Grid.Row="4" Margin="0,2,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0">
                                    <!-- 回车直接提交;长文本自动换行；高度由 InputBarRow 控制 -->
                                    <TextBox x:Name="NewTaskBox" Style="{StaticResource FlatTextBox}"
                                             Padding="6,4" VerticalContentAlignment="Top"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding AddTaskCommand}" />
                                        </TextBox.InputBindings>
                                    </TextBox>
                                    <TextBlock Text="{DynamicResource S.Input.Placeholder}" Margin="8,0,0,0"
                                               VerticalAlignment="Center" IsHitTestVisible="False"
                                               TextAlignment="Left" HorizontalAlignment="Left">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource MutedText}" />
                                                <!-- 默认隐藏；仅当输入为空、且文本框未获得焦点(未点击进入)时才显示提示，单击进入即移除 -->
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding NewTaskTitle}" Value="" />
                                                            <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=NewTaskBox}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <!-- 语音输入：调起 Windows 系统语音输入(Win+H)，识别文字直接进入输入框 -->
                                <Button Grid.Column="1" Style="{StaticResource GhostButton}"
                                        Margin="8,0,0,0" Padding="10,0"
                                        VerticalAlignment="Stretch"
                                        Background="{DynamicResource InputBg}"
                                        ToolTip="{DynamicResource S.Tip.Voice}"
                                        Click="VoiceInput_Click">
                                    <TextBlock Text="&#xE720;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="15" />
                                </Button>

                                <Button Grid.Column="2" Style="{StaticResource AccentButton}" Content="{DynamicResource S.Add}"
                                        Margin="8,0,0,0" VerticalAlignment="Stretch" Padding="10,0" MinWidth="56"
                                        Command="{Binding AddTaskCommand}" />
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ==================== 便签视图(v1.2.0):与任务区互斥占据中央区域 ==================== -->
                    <!-- 注意:NotesView 的 DataContext 在 Init 后是 NotesViewModel,必须显式绑窗口 DataContext 才能读到 IsNotesViewOpen -->
                    <v:NotesView x:Name="NotesPanel" Grid.Column="2" Margin="16,16,16,16"
                                 Visibility="{Binding DataContext.IsNotesViewOpen, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}" />

                    <!-- 日程分隔条:拖动调整中间任务区与右侧日程的宽度(收起时隐藏) -->
                    <GridSplitter x:Name="ScheduleSplitter" Grid.Column="3" Width="5"
                                  HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                  Background="Transparent" ResizeBehavior="PreviousAndNext"
                                  Visibility="Collapsed" />

                    <!-- ==================== 右侧:日程面板(嵌入,可拖宽) ==================== -->
                    <Border x:Name="SchedulePanel" Grid.Column="4" Visibility="Collapsed"
                            Background="{DynamicResource SidebarBg}"
                            BorderBrush="{DynamicResource Divider}" BorderThickness="1,0,0,0">
                        <v:CalendarView x:Name="ScheduleView" />
                    </Border>
                </Grid>
            </Grid>

            <!-- 完成庆祝：烟花粒子覆盖层（不拦截鼠标，浮于全部内容之上） -->
            <Canvas x:Name="FxOverlay" IsHitTestVisible="False" ClipToBounds="True" />

            <!-- 换肤交叉淡变：切主题前的旧主题截图盖在最上层，换肤后淡出（不拦截鼠标） -->
            <Image x:Name="ThemeFadeOverlay" IsHitTestVisible="False" Stretch="Fill"
                   Visibility="Collapsed" />
        </Grid>
    </Border>
</Window>
