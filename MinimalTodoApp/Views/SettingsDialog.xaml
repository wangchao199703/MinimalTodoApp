<Window x:Class="MinimalTodoApp.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.Settings.Title}"
        SizeToContent="WidthAndHeight"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        FontFamily="Microsoft YaHei UI, Segoe UI">

    <Border Background="{DynamicResource WindowBg}" CornerRadius="12"
            BorderBrush="{DynamicResource Divider}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.35" Color="#000000" />
        </Border.Effect>
        <StackPanel Margin="22" Width="320">
            <TextBlock Text="{DynamicResource S.Settings.Title}" FontSize="16" FontWeight="Bold"
                       Margin="0,0,0,16" Foreground="{DynamicResource PrimaryText}" />

            <!-- 开机自启动 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{DynamicResource S.Settings.AutoStart}" FontSize="14"
                               Foreground="{DynamicResource PrimaryText}" />
                    <TextBlock Text="{DynamicResource S.Settings.AutoStartDesc}" FontSize="11"
                               Margin="0,2,0,0" Foreground="{DynamicResource MutedText}" />
                </StackPanel>
                <CheckBox x:Name="AutoStartCheck" Grid.Column="1" VerticalAlignment="Center"
                          Checked="AutoStart_Changed" Unchecked="AutoStart_Changed" />
            </Grid>

            <Border Height="1" Background="{DynamicResource Divider}" Margin="0,16,0,16" />

            <!-- 完成庆祝特效 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{DynamicResource S.Settings.Effects}" FontSize="14"
                               Foreground="{DynamicResource PrimaryText}" />
                    <TextBlock Text="{DynamicResource S.Settings.EffectsDesc}" FontSize="11"
                               Margin="0,2,0,0" Foreground="{DynamicResource MutedText}" />
                </StackPanel>
                <CheckBox x:Name="EffectsCheck" Grid.Column="1" VerticalAlignment="Center"
                          Checked="Effects_Changed" Unchecked="Effects_Changed" />
            </Grid>

            <!-- 完成庆祝音效 -->
            <Grid Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{DynamicResource S.Settings.Sound}" FontSize="14"
                               Foreground="{DynamicResource PrimaryText}" />
                    <TextBlock Text="{DynamicResource S.Settings.SoundDesc}" FontSize="11"
                               Margin="0,2,0,0" Foreground="{DynamicResource MutedText}" />
                </StackPanel>
                <CheckBox x:Name="SoundCheck" Grid.Column="1" VerticalAlignment="Center"
                          Checked="Sound_Changed" Unchecked="Sound_Changed" />
            </Grid>

            <!-- 周期提醒音效 -->
            <Grid Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{DynamicResource S.Settings.ReminderSound}" FontSize="14"
                               Foreground="{DynamicResource PrimaryText}" />
                    <TextBlock Text="{DynamicResource S.Settings.ReminderSoundDesc}"
                               FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap"
                               Foreground="{DynamicResource MutedText}" />
                </StackPanel>
                <CheckBox x:Name="ReminderSoundCheck" Grid.Column="1" VerticalAlignment="Center"
                          Checked="ReminderSound_Changed" Unchecked="ReminderSound_Changed" />
            </Grid>

            <Border Height="1" Background="{DynamicResource Divider}" Margin="0,16,0,16" />

            <!-- 字体 / 字号 / 行距(作用于任务与正文文字) -->
            <TextBlock Text="{DynamicResource S.Settings.Font}" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,2" />
            <TextBlock Text="{DynamicResource S.Settings.FontDesc}" FontSize="11" Margin="0,0,0,12"
                       TextWrapping="Wrap" Foreground="{DynamicResource MutedText}" />

            <!-- 字体 -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="76" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource S.Settings.FontFamily}" FontSize="13"
                           VerticalAlignment="Center" Foreground="{DynamicResource SecondaryText}" />
                <ComboBox Grid.Column="1" ItemsSource="{Binding Fonts}" SelectedItem="{Binding SelectedFont}"
                          DisplayMemberPath="Display" VerticalContentAlignment="Center" />
            </Grid>

            <!-- 字号 -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="76" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="36" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource S.Settings.FontSize}" FontSize="13"
                           VerticalAlignment="Center" Foreground="{DynamicResource SecondaryText}" />
                <Slider Grid.Column="1" Minimum="10" Maximum="18" Value="{Binding FontSize, Mode=TwoWay}"
                        TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="{Binding FontSize, StringFormat={}{0:0}}" FontSize="12"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedText}" />
            </Grid>

            <!-- 字号快捷档位:小(12) / 中(14) / 大(16)，一键调整待办与正文字号 -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="76" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource GhostButton}" Content="{DynamicResource S.Size.Small}"
                            Tag="10" Click="FontPreset_Click" MinWidth="52" Padding="0,5"
                            Margin="0,0,8,0" Background="{DynamicResource InputBg}" />
                    <Button Style="{StaticResource GhostButton}" Content="{DynamicResource S.Size.Medium}"
                            Tag="12" Click="FontPreset_Click" MinWidth="52" Padding="0,5"
                            Margin="0,0,8,0" Background="{DynamicResource InputBg}" />
                    <Button Style="{StaticResource GhostButton}" Content="{DynamicResource S.Size.Large}"
                            Tag="14" Click="FontPreset_Click" MinWidth="52" Padding="0,5"
                            Background="{DynamicResource InputBg}" />
                </StackPanel>
            </Grid>

            <!-- 行距 -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="76" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="36" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource S.Settings.LineSpacing}" FontSize="13"
                           VerticalAlignment="Center" Foreground="{DynamicResource SecondaryText}" />
                <Slider Grid.Column="1" Minimum="0.8" Maximum="1.8" Value="{Binding LineSpacing, Mode=TwoWay}"
                        TickFrequency="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="{Binding LineSpacing, StringFormat={}{0:0.0}}" FontSize="12"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedText}" />
            </Grid>

            <!-- 勾选框大小 -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="76" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="36" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource S.Settings.CheckboxSize}" FontSize="13"
                           VerticalAlignment="Center" Foreground="{DynamicResource SecondaryText}" />
                <Slider Grid.Column="1" Minimum="12" Maximum="24" Value="{Binding CheckboxSize, Mode=TwoWay}"
                        TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="{Binding CheckboxSize, StringFormat={}{0:0}}" FontSize="12"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedText}" />
            </Grid>

            <TextBlock x:Name="StatusText" FontSize="11" Margin="0,12,0,0"
                       Foreground="{DynamicResource MutedText}" TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="{DynamicResource S.Close}" Style="{StaticResource AccentButton}" Click="Close_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
