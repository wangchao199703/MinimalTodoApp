<Window x:Class="MinimalTodoApp.Views.ThemeEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.ThemeEditor.Title}"
        SizeToContent="Height" Width="380"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        FontFamily="Microsoft YaHei UI, Segoe UI">

    <Border Background="{DynamicResource PopupBg}" CornerRadius="12"
            BorderBrush="{DynamicResource Divider}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.35" Color="#000000" />
        </Border.Effect>
        <StackPanel Margin="22">
            <TextBlock Text="{DynamicResource S.ThemeEditor.Title}" FontSize="16" FontWeight="Bold"
                       Margin="0,0,0,14" Foreground="{DynamicResource PrimaryText}" />

            <!-- 名称 -->
            <TextBlock Text="{DynamicResource S.ThemeEditor.Name}" FontSize="13" Margin="0,0,0,5"
                       Foreground="{DynamicResource SecondaryText}" />
            <TextBox x:Name="NameBox" Style="{StaticResource FlatTextBox}"
                     Text="{DynamicResource S.ThemeEditor.DefaultName}" Margin="0,0,0,14" />

            <!-- 以现有主题为基础 -->
            <TextBlock Text="{DynamicResource S.ThemeEditor.BaseOn}" FontSize="13" Margin="0,0,0,5"
                       Foreground="{DynamicResource SecondaryText}" />
            <ComboBox x:Name="BaseBox" Margin="0,0,0,14"
                      DisplayMemberPath="Display" SelectionChanged="BaseBox_SelectionChanged" />

            <!-- 颜色字段 -->
            <ItemsControl x:Name="FieldList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource PrimaryText}" FontSize="13" />
                            <Border Grid.Column="1" Width="20" Height="20" CornerRadius="4"
                                    BorderBrush="{DynamicResource Divider}" BorderThickness="1"
                                    Background="{Binding Value, Converter={StaticResource StringToBrush}}" />
                            <TextBox Grid.Column="2" Style="{StaticResource FlatTextBox}" Margin="6,0,0,0"
                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="{DynamicResource S.ThemeEditor.ColorHint}" FontSize="11"
                       Margin="0,2,0,0" Foreground="{DynamicResource MutedText}" TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="{DynamicResource S.Cancel}" Style="{StaticResource GhostButton}"
                        Click="Cancel_Click" Margin="0,0,8,0" />
                <Button Content="{DynamicResource S.SaveApply}" Style="{StaticResource AccentButton}"
                        Click="Ok_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
