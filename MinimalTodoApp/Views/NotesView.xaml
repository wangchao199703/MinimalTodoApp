<UserControl x:Class="MinimalTodoApp.Views.NotesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MinimalTodoApp.Converters"
             xmlns:inf="clr-namespace:MinimalTodoApp.Infrastructure"
             FontFamily="Microsoft YaHei UI, Segoe UI">

    <UserControl.Resources>
        <conv:BlockFontSizeConverter x:Key="BlockFontSize" />

        <!-- 工具栏小按钮:GhostButton 收紧内边距;Focusable=False 是不夺走编辑框焦点的关键 -->
        <Style x:Key="NoteToolButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <!-- ===== 顶部条:便签选择/新建/删除 | 格式工具栏 | 提取待办 ===== -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 便签选择 -->
            <ComboBox Grid.Column="0" MinWidth="150" MaxWidth="220" VerticalAlignment="Center"
                      ItemsSource="{Binding Notes}" SelectedItem="{Binding SelectedNote, Mode=TwoWay}"
                      DisplayMemberPath="DisplayTitle" />

            <!-- 新建 / 删除便签 -->
            <Button Grid.Column="1" Style="{StaticResource IconButton}" Margin="6,0,0,0"
                    Focusable="False" Command="{Binding NewNoteCommand}"
                    ToolTip="{DynamicResource S.Note.New}">
                <TextBlock Text="&#xE710;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13" />
            </Button>
            <Button Grid.Column="2" Style="{StaticResource IconButton}" Margin="2,0,0,0"
                    Focusable="False" Click="DeleteNote_Click"
                    ToolTip="{DynamicResource S.Note.Delete}">
                <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13" />
            </Button>

            <!-- 分隔 -->
            <Border Grid.Column="3" Width="1" Margin="10,4" Background="{DynamicResource Divider}" />

            <!-- 格式工具栏 -->
            <Button Grid.Column="4" Style="{StaticResource NoteToolButton}" FontWeight="Bold"
                    Content="B" Click="BoldButton_Click" ToolTip="{DynamicResource S.Note.Bold}" />
            <Button Grid.Column="5" Style="{StaticResource NoteToolButton}"
                    Content="H" Click="HeadingButton_Click" ToolTip="{DynamicResource S.Note.Heading}" />
            <Button Grid.Column="6" Style="{StaticResource NoteToolButton}"
                    Content="•" Click="BulletButton_Click" ToolTip="{DynamicResource S.Note.Bullet}" />
            <Button Grid.Column="7" Style="{StaticResource NoteToolButton}"
                    Content="☐" Click="TaskButton_Click" ToolTip="{DynamicResource S.Note.TaskList}" />

            <!-- 返回待办:切回任务列表(MD 文本常驻,任务块自动转成待办) -->
            <Button Grid.Column="9" Style="{StaticResource GhostButton}" Padding="10,5"
                    Focusable="False" Click="BackToTasks_Click"
                    ToolTip="{DynamicResource S.Note.BackToTasks}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="13" VerticalAlignment="Center" />
                    <TextBlock Text="{DynamicResource S.Note.BackToTasks}" Margin="6,0,0,0"
                               FontSize="12" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- ===== 块编辑器 ===== -->
        <Border CornerRadius="10" Background="{DynamicResource CardBg}"
                BorderBrush="{DynamicResource Divider}" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,10">
                <StackPanel>
                    <!-- 无虚拟化 ItemsControl:虚拟化会回收编辑中的 TextBox 导致焦点/光标灾难 -->
                    <ItemsControl x:Name="BlockList" ItemsSource="{Binding CurrentBlocks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- 任务块前缀:复选框(强调色圆环，与任务列表同款) -->
                                    <CheckBox x:Name="TaskCheck" Style="{StaticResource TaskCheckBox}"
                                              BorderBrush="{DynamicResource Accent}"
                                              IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                              VerticalAlignment="Top" Margin="1,7,9,0"
                                              Visibility="Collapsed" />
                                    <!-- 无序列表前缀:圆点 -->
                                    <TextBlock x:Name="BulletDot" Text="•" FontWeight="Bold"
                                               Foreground="{DynamicResource Accent}"
                                               VerticalAlignment="Top" Margin="4,4,11,0"
                                               Visibility="Collapsed" />

                                    <!-- 内容:显示层(渲染 **加粗**) / 编辑层(原始文本)双控件互斥 -->
                                    <Grid Grid.Column="1">
                                        <TextBlock x:Name="Display"
                                                   inf:InlineMarkdown.Text="{Binding Text}"
                                                   TextWrapping="Wrap" Padding="4,4" Cursor="IBeam"
                                                   LineStackingStrategy="MaxHeight" LineHeight="Auto"
                                                   MouseLeftButtonUp="BlockDisplay_Click"
                                                   Background="Transparent" MinHeight="26"
                                                   Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                                            <TextBlock.FontSize>
                                                <MultiBinding Converter="{StaticResource BlockFontSize}">
                                                    <Binding Path="Type" />
                                                    <Binding Path="DataContext.FontSize" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                </MultiBinding>
                                            </TextBlock.FontSize>
                                        </TextBlock>

                                        <TextBox x:Name="Editor"
                                                 Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="Transparent" BorderThickness="0" Padding="4,4"
                                                 TextWrapping="Wrap" AcceptsReturn="False" MinHeight="26"
                                                 Foreground="{DynamicResource PrimaryText}"
                                                 CaretBrush="{DynamicResource PrimaryText}"
                                                 FontFamily="{DynamicResource AppFontFamily}"
                                                 IsVisibleChanged="BlockEditor_IsVisibleChanged"
                                                 LostKeyboardFocus="BlockEditor_LostFocus"
                                                 PreviewKeyDown="BlockEditor_PreviewKeyDown"
                                                 TextChanged="BlockEditor_TextChanged"
                                                 Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                                            <TextBox.FontSize>
                                                <MultiBinding Converter="{StaticResource BlockFontSize}">
                                                    <Binding Path="Type" />
                                                    <Binding Path="DataContext.FontSize" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                </MultiBinding>
                                            </TextBox.FontSize>
                                        </TextBox>
                                    </Grid>
                                </Grid>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Type}" Value="Task">
                                        <Setter TargetName="TaskCheck" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Type}" Value="Bullet">
                                        <Setter TargetName="BulletDot" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Type}" Value="H1">
                                        <Setter TargetName="Display" Property="FontWeight" Value="Bold" />
                                        <Setter TargetName="Editor" Property="FontWeight" Value="Bold" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Type}" Value="H2">
                                        <Setter TargetName="Display" Property="FontWeight" Value="Bold" />
                                        <Setter TargetName="Editor" Property="FontWeight" Value="Bold" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Type}" Value="H3">
                                        <Setter TargetName="Display" Property="FontWeight" Value="SemiBold" />
                                        <Setter TargetName="Editor" Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                    <!-- 已完成任务块:删除线 + 弱化 -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Type}" Value="Task" />
                                            <Condition Binding="{Binding IsChecked}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="Display" Property="TextDecorations" Value="Strikethrough" />
                                        <Setter TargetName="Display" Property="Foreground" Value="{DynamicResource MutedText}" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 尾部留白:点击在末尾追加段落进入编辑(Notion 手感) -->
                    <Border x:Name="TailClicker" Height="80" Background="Transparent" Cursor="IBeam"
                            MouseLeftButtonUp="TailClicker_Click" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </DockPanel>
</UserControl>
