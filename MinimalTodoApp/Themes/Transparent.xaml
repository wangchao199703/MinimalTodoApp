<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 透明主题：窗口半透明，可看到桌面背景（键名必须与其它主题一致） -->
    <SolidColorBrush x:Key="WindowBg"       Color="#CCFFFFFF" />
    <SolidColorBrush x:Key="TitleBarBg"     Color="#33FFFFFF" />
    <SolidColorBrush x:Key="SidebarBg"      Color="#22FFFFFF" />
    <SolidColorBrush x:Key="ContentBg"      Color="#00FFFFFF" />
    <SolidColorBrush x:Key="CardBg"         Color="#AAFFFFFF" />
    <SolidColorBrush x:Key="CardHoverBg"    Color="#CCFFFFFF" />
    <SolidColorBrush x:Key="InputBg"        Color="#88FFFFFF" />
    <SolidColorBrush x:Key="PrimaryText"    Color="#15181C" />
    <SolidColorBrush x:Key="SecondaryText"  Color="#3C434C" />
    <SolidColorBrush x:Key="MutedText"      Color="#5A6470" />
    <SolidColorBrush x:Key="Accent"         Color="#3B82F6" />
    <SolidColorBrush x:Key="AccentText"     Color="#FFFFFF" />
    <SolidColorBrush x:Key="Divider"        Color="#33000000" />
    <SolidColorBrush x:Key="SelectedItemBg" Color="#553B82F6" />
    <SolidColorBrush x:Key="OverdueText"    Color="#D32F2F" />
    <SolidColorBrush x:Key="WarningText"    Color="#B26A00" />
    <SolidColorBrush x:Key="SuccessText"    Color="#15803D" />

</ResourceDictionary>
