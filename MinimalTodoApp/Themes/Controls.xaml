<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:MinimalTodoApp.Converters">

    <!-- ===================== 转换器 ===================== -->
    <conv:NullToBoolConverter x:Key="NullToBool" />
    <conv:InverseBooleanConverter x:Key="InverseBool" />
    <conv:EmptyStringToVisibilityConverter x:Key="EmptyToVis" />
    <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    <conv:DueDateDisplayConverter x:Key="DueDisplay" />
    <conv:StringToBrushConverter x:Key="StringToBrush" />
    <conv:DueStateToBrushConverter x:Key="DueStateToBrush" />
    <conv:PriorityToBrushConverter x:Key="PriorityToBrush" />
    <conv:PriorityToTextConverter x:Key="PriorityToText" />
    <conv:EqualityToBoolConverter x:Key="EqualityToBool" />
    <conv:IndentToMarginConverter x:Key="IndentToMargin" />

    <!-- ===================== 基础文字（字体/字号/行距随设置实时变化） ===================== -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource AppFontSize}" />
        <Setter Property="LineHeight" Value="{DynamicResource AppLineHeight}" />
        <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
    </Style>

    <!-- ===================== 主按钮 ===================== -->
    <Style x:Key="AccentButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource AccentText}" />
        <Setter Property="Background" Value="{DynamicResource Accent}" />
        <Setter Property="Padding" Value="16,9" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Opacity" Value="0.88" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="b" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 幽灵按钮（透明，hover 显底色） ===================== -->
    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource SecondaryText}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource CardHoverBg}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 小图标按钮（删除 ×、添加 +） ===================== -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource MutedText}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="26" />
        <Setter Property="Height" Value="26" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="5">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource CardHoverBg}" />
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 圆角输入框 ===================== -->
    <Style x:Key="FlatTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource InputBg}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
        <Setter Property="CaretBrush" Value="{DynamicResource PrimaryText}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="FontSize" Value="{DynamicResource AppFontSize}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="TextAlignment" Value="Left" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}" CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 透明内联标题编辑框 ===================== -->
    <Style x:Key="TaskTitleTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
        <Setter Property="CaretBrush" Value="{DynamicResource PrimaryText}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="2,1" />
        <Setter Property="FontSize" Value="{DynamicResource AppFontSize}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 扁平 ListBox（无边框/背景） ===================== -->
    <Style x:Key="FlatListBox" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>

    <!-- ===================== 侧边栏分组项 ===================== -->
    <Style x:Key="SidebarItemStyle" TargetType="ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="b" Background="Transparent" CornerRadius="8" Padding="10,8">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource CardHoverBg}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource SelectedItemBg}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 任务项容器 ===================== -->
    <Style x:Key="TaskItemStyle" TargetType="ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Margin" Value="{DynamicResource AppTaskItemMargin}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="b" Background="{DynamicResource CardBg}"
                            BorderBrush="{DynamicResource Divider}" BorderThickness="1"
                            CornerRadius="12" Padding="14,12">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource CardHoverBg}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 任务圆形勾选框（圆环按优先级着色，完成时填充 + 白色对勾） ===================== -->
    <!-- 用法：BorderBrush 绑定到 PriorityToBrush，圆环/填充即随优先级着色（取代旧的左侧色条与方框） -->
    <Style x:Key="TaskCheckBox" TargetType="CheckBox">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Width="22" Height="22" Background="Transparent">
                        <!-- 外圆环：颜色取自 BorderBrush（= 优先级色） -->
                        <Ellipse x:Name="ring" Width="20" Height="20"
                                 Stroke="{TemplateBinding BorderBrush}" StrokeThickness="2"
                                 Fill="Transparent" />
                        <!-- 完成时的白色对勾 -->
                        <Path x:Name="check" Data="M 6 11 L 9.3 14.3 L 15.5 7"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Stroke="White" StrokeThickness="2.2"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              StrokeLineJoin="Round" Opacity="0" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ring" Property="Fill" Value="{DynamicResource CardHoverBg}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="ring" Property="Fill"
                                    Value="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter TargetName="check" Property="Opacity" Value="1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 标题栏按钮（最小化 / 关闭到托盘） ===================== -->
    <Style x:Key="CaptionButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource SecondaryText}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="26" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource CardHoverBg}" />
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 标题栏切换按钮（ToggleButton 版，用于主题/排序/设置弹层） ===================== -->
    <Style x:Key="CaptionToggleButton" TargetType="ToggleButton">
        <Setter Property="Foreground" Value="{DynamicResource SecondaryText}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="26" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource CardHoverBg}" />
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource SelectedItemBg}" />
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 侧边栏整宽切换按钮（展开=居中文字，折叠=居中图标，带 Popup） ===================== -->
    <Style x:Key="SidebarToggleButton" TargetType="ToggleButton">
        <Setter Property="Foreground" Value="{DynamicResource SecondaryText}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="6,7" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource CardHoverBg}" />
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource SelectedItemBg}" />
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 关闭到托盘按钮：hover 变红 -->
    <Style x:Key="CaptionCloseButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#E5484D" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== Mac 风格交通灯按钮 ===================== -->
    <!-- 用法：Tag 设为圆点颜色；Content 设为悬停时显示的符号（如 ✕ – +） -->
    <Style x:Key="TrafficLightButton" TargetType="Button">
        <Setter Property="Width" Value="13" />
        <Setter Property="Height" Value="13" />
        <Setter Property="Margin" Value="4,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="#80000000" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <!-- 用普通 Binding（而非 TemplateBinding）以便把 Tag 的十六进制字符串转换为画刷 -->
                        <Ellipse x:Name="dot"
                                 Fill="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                 Stroke="#22000000" StrokeThickness="0.5" />
                        <TextBlock x:Name="glyph" Text="{TemplateBinding Content}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{TemplateBinding Foreground}" Opacity="0" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="glyph" Property="Opacity" Value="1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== 现代细长滚动条 ===================== -->
    <!-- 半透明灰：在明亮/暗黑/透明等所有主题上都清晰可辨，无需逐主题配色 -->
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#73888888" />
    <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#B3888888" />

    <!-- 翻页区：完全透明、不抢焦点（去掉默认的方块/箭头按钮） -->
    <Style x:Key="ScrollBarPageButton" TargetType="RepeatButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 圆角滑块：默认半透明，悬停/拖动时加深 -->
    <Style x:Key="ScrollThumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="t" CornerRadius="4" Margin="2"
                            Background="{DynamicResource ScrollThumbBrush}" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="t" Property="Background" Value="{DynamicResource ScrollThumbHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="t" Property="Background" Value="{DynamicResource ScrollThumbHoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 默认（无 Key）样式：应用到所有 ScrollBar，含任务列表内的滚动条 -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="10" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent" SnapsToDevicePixels="True">
                        <Track x:Name="PART_Track" Orientation="{TemplateBinding Orientation}"
                               IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                                              Command="ScrollBar.PageUpCommand" />
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                                              Command="ScrollBar.PageDownCommand" />
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ScrollThumb}" MinHeight="28" MinWidth="28" />
                            </Track.Thumb>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto" />
                <Setter Property="Height" Value="10" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ===================== 优先级选择 Chip（对话框用） ===================== -->
    <Style x:Key="PriorityChip" TargetType="RadioButton">
        <Setter Property="Margin" Value="3,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="b" CornerRadius="6" Padding="0,8"
                            Background="{DynamicResource InputBg}"
                            BorderThickness="1.5" BorderBrush="Transparent">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource CardHoverBg}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <!-- 选中时用 Tag 指定的优先级色描边 + 着色 -->
                            <Setter TargetName="b" Property="BorderBrush" Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter Property="Foreground" Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter Property="FontWeight" Value="Bold" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
