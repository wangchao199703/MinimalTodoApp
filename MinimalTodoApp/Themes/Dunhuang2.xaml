<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 敦煌·土红（暖砂底 + 壁画土红，浅色） -->
    <SolidColorBrush x:Key="WindowBg"       Color="#F4E9DD" />
    <SolidColorBrush x:Key="TitleBarBg"     Color="#ECDBC9" />
    <SolidColorBrush x:Key="SidebarBg"      Color="#F0E0CF" />
    <SolidColorBrush x:Key="ContentBg"      Color="#F8EFE4" />
    <SolidColorBrush x:Key="CardBg"         Color="#FDF8EF" />
    <SolidColorBrush x:Key="CardHoverBg"    Color="#F1E2D0" />
    <SolidColorBrush x:Key="InputBg"        Color="#F0E0CF" />
    <SolidColorBrush x:Key="PrimaryText"    Color="#3D2A22" />
    <SolidColorBrush x:Key="SecondaryText"  Color="#6F5346" />
    <SolidColorBrush x:Key="MutedText"      Color="#A48978" />
    <SolidColorBrush x:Key="Accent"         Color="#B5533A" />
    <SolidColorBrush x:Key="AccentText"     Color="#FFFFFF" />
    <SolidColorBrush x:Key="Divider"        Color="#E2CDB8" />
    <SolidColorBrush x:Key="SelectedItemBg" Color="#F0DAC9" />
    <SolidColorBrush x:Key="OverdueText"    Color="#A8332B" />
    <SolidColorBrush x:Key="WarningText"    Color="#C0822E" />
    <SolidColorBrush x:Key="SuccessText"    Color="#5E8A5A" />

    <SolidColorBrush x:Key="PopupBg"        Color="#FDF8EF" />
</ResourceDictionary>
